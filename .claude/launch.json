{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite / React)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "Backend (Express / Nodemon)",
      "runtimeExecutable": "cmd.exe",
      "runtimeArgs": ["/c", "npm", "--prefix", "backend", "run", "dev"],
      "port": 5000
    }
  ]
}
